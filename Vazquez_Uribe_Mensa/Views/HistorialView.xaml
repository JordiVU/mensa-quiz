<UserControl x:Class="Vazquez_Uribe_Mensa.Views.HistorialView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="768" d:DesignWidth="1106">

    <UserControl.Resources>
        <FontFamily x:Key="IconFont">Segoe MDL2 Assets, Segoe UI Symbol</FontFamily>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="25,20"/>
        </Style>
    </UserControl.Resources>

    <Border Background="#F8F9FA" Padding="40">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- cabecera -->
                <Grid Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding Titulo}" FontSize="28"
                   FontWeight="SemiBold" Foreground="Black" Margin="0,0,0,5"/>
                        <TextBlock Text="Rastrea el rendimiento y participación de tus quizzes"
                   FontSize="18" Foreground="#6B7280"/>
                    </StackPanel>

                    <!-- botón PDF solo admin -->
                    <Button Grid.Column="1" VerticalAlignment="Bottom"
                            Command="{Binding GenerarPdfCommand}"
                            Background="#EF4444" Foreground="White"
                            FontWeight="SemiBold" FontSize="14"
                            Padding="15,10" Cursor="Hand"
                            BorderThickness="0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#DC2626"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EsAdmin}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE8A1;"
                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Exportar PDF" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- tarjetas estadísticas -->
                <Grid Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource StatCardStyle}">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.03" BlurRadius="10" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE8A5;"
                                       FontSize="24" Foreground="#FF9800" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding TotalQuizzes}" FontSize="32"
                                       FontWeight="Bold" Foreground="Black"/>
                            <TextBlock Text="Total Quizzes Creados" Style="{StaticResource LabelStyle}"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource StatCardStyle}">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.03" BlurRadius="10" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE716;"
                                       FontSize="24" Foreground="#FF9800" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding TotalParticipantes}" FontSize="32"
                                       FontWeight="Bold" Foreground="Black"/>
                            <TextBlock Text="Total Participantes" Style="{StaticResource LabelStyle}"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Style="{StaticResource StatCardStyle}">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.03" BlurRadius="10" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE916;"
                                       FontSize="24" Foreground="#FF9800" Margin="0,0,0,10"/>
                            <TextBlock FontSize="32" FontWeight="Bold" Foreground="Black">
                                <Run Text="{Binding TiempoMedio, Mode=OneWay}"/>
                                <Run Text=" min"/>
                            </TextBlock>
                            <TextBlock Text="Tiempo Medio" Style="{StaticResource LabelStyle}"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="6" Style="{StaticResource StatCardStyle}">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.03" BlurRadius="10" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE81C;"
                                       FontSize="24" Foreground="#FF9800" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding TotalSesiones}" FontSize="32"
                                       FontWeight="Bold" Foreground="Black"/>
                            <TextBlock Text="Total Sesiones" Style="{StaticResource LabelStyle}"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- gráfica actividad por mes -->
                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1"
                        CornerRadius="8" Padding="25" Margin="0,0,0,25">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.03" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Actividad por mes" FontSize="16"
                                   FontWeight="SemiBold" Margin="0,0,0,20"/>
                        <ItemsControl ItemsSource="{Binding DatosPorMes}" Height="150">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel HorizontalAlignment="Center">
                                        <Grid VerticalAlignment="Bottom" Height="120">
                                            <Rectangle VerticalAlignment="Bottom"
                                                       Width="20" Fill="#FF9800"
                                                       RadiusX="3" RadiusY="3"
                                                       Height="{Binding Altura}"/>
                                        </Grid>
                                        <TextBlock Text="{Binding Mes}" FontSize="11"
                                                   Foreground="#9CA3AF"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- lista sesiones -->
                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1"
                        CornerRadius="8" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.03" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Sesiones realizadas" FontSize="16"
                                   FontWeight="SemiBold" Margin="0,0,0,15"/>

                        <Grid Margin="15,0,15,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Quiz" FontWeight="SemiBold"
                                       FontSize="13" Foreground="#374151"/>
                            <TextBlock Grid.Column="1" Text="Fecha" FontWeight="SemiBold"
                                       FontSize="13" Foreground="#374151"/>
                            <TextBlock Grid.Column="2" Text="Participantes" FontWeight="SemiBold"
                                       FontSize="13" Foreground="#374151"/>
                            <TextBlock Grid.Column="3" Text="Duración" FontWeight="SemiBold"
                                       FontSize="13" Foreground="#374151"/>
                        </Grid>
                        <Separator Background="#E5E7EB" Margin="0,0,0,5"/>

                        <TextBlock Text="Aún no hay sesiones registradas."
                                   Foreground="#9CA3AF" FontSize="14"
                                   HorizontalAlignment="Center" Margin="0,20">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Sesiones.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ItemsControl ItemsSource="{Binding Sesiones}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1"
                                            Padding="15,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding TituloQuiz}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                       Foreground="#6B7280" FontSize="13">
                                                <Run Text="{Binding Fecha, StringFormat={}{0:dd/MM/yyyy}, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                       Foreground="#6B7280" FontSize="13">
                                                <Run Text="{Binding Participantes, Mode=OneWay}"/>
                                                <Run Text=" personas"/>
                                            </TextBlock>
                                            <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                                       Foreground="#6B7280" FontSize="13">
                                                <Run Text="{Binding Duracion, Mode=OneWay}"/>
                                                <Run Text=" min"/>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>