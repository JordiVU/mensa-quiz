<Window x:Class="Vazquez_Uribe_Mensa.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:Vazquez_Uribe_Mensa.Views"
        xmlns:vm="clr-namespace:Vazquez_Uribe_Mensa.ViewModels"
        mc:Ignorable="d" 
        Title="Mensa - Gestión de Quizzes" Height="768" Width="1366" WindowStartupLocation="CenterScreen"
        Icon="/Images/logoMensa.ico">

    <Window.Resources>
        <!-- Iconos -->
        <FontFamily x:Key="IconFont">Segoe MDL2 Assets, Segoe UI Symbol</FontFamily>

        <!-- Vistas -->
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <local:LoginView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PrincipalViewModel}">
            <local:PrincipalView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:HistorialViewModel}">
            <local:HistorialView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:AdminPanelViewModel}">
            <local:AdminPanelView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:QuizBuilderViewModel}">
            <local:QuizBuilderView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:QuizPlayerViewModel}">
            <local:QuizPlayerView />
        </DataTemplate>

        <!-- Botones menú lateral -->
        <Style x:Key="MenuButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <!-- Estado deshabilitado -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- MENU LATERAL -->
        <Border Grid.Column="0" Background="#111827">
            <StackPanel>
                <Border Width="150" Height="150" CornerRadius="50" Margin="0,40,0,20">
                    <Image Source="/Images/logoMensa.png" Stretch="Uniform" Margin="15"/>
                </Border>

                <!-- Aviso sin login -->
                <TextBlock Text="Inicia sesión para navegar" 
                           Foreground="#FFA000" 
                           FontSize="14" 
                           FontStyle="Italic"
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,30">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoggedIn}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Menú usuarios logueados -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoggedIn}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <RadioButton GroupName="SideMenu" Style="{StaticResource MenuButtonStyle}" 
                                 Command="{Binding ShowPrincipalCommand}" IsChecked="True">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource IconFont}" 
                                       Text="&#xE8A5;" Margin="0,0,15,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Mis Quizzes" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton GroupName="SideMenu" Style="{StaticResource MenuButtonStyle}" 
                                 Command="{Binding ShowHistorialCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource IconFont}" 
                                       Text="&#xE81C;" Margin="0,0,15,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Historial" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton GroupName="SideMenu" Command="{Binding ShowAdminPanelCommand}">
                        <RadioButton.Style>
                            <Style TargetType="RadioButton" BasedOn="{StaticResource MenuButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Usuario.Role}" Value="Admin">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </RadioButton.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource IconFont}"
                   Text="&#xE713;" Margin="0,0,15,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Panel Admin" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Logout -->
                    <Button Content="Cerrar Sesión"
                        Command="{Binding LogoutCommand}"
                        Margin="20,280,20,20"
                        Padding="10,12"
                        Cursor="Hand"
                        Background="#EF4444"
                        Foreground="White"
                        FontSize="16"
                        BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#DC2626"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- CONTENIDO PRINCIPAL -->
        <ContentControl Grid.Column="1" 
                        Content="{Binding CurrentView}" />

    </Grid>
</Window>