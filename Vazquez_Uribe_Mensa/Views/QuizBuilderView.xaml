<UserControl x:Class="Vazquez_Uribe_Mensa.Views.QuizBuilderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1106">

    <UserControl.Resources>
        <FontFamily x:Key="IconFont">Segoe MDL2 Assets, Segoe UI Symbol</FontFamily>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="OrangeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF9800"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F57C00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GrayButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D1D5DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TipoButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFF8E1"/>
                                <Setter Property="BorderBrush" Value="#FF9800"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10,10"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#F8F9FA" Padding="40">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <Grid Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Foreground="#6B7280" FontSize="14" Margin="0,0,0,5">
                            <Hyperlink Command="{Binding CancelarCommand}"
                                       Foreground="#6B7280" TextDecorations="None">
                                ← Volver a mis Quizzes
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock Text="{Binding TituloVista}" FontSize="28" FontWeight="SemiBold" Foreground="Black"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button Style="{StaticResource GrayButtonStyle}"
                                Command="{Binding CancelarCommand}"
                                Margin="0,0,10,0" Width="120">
                            Cancelar
                        </Button>
                        <Button Style="{StaticResource OrangeButtonStyle}"
                                Command="{Binding GuardarCommand}" Width="140">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE74E;"
                                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Guardar Quiz" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1"
                        CornerRadius="8" Padding="30" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.03" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Título del Quiz *" Style="{StaticResource LabelStyle}"/>
                            <TextBox Style="{StaticResource InputStyle}"
                                     Text="{Binding Titulo, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="200"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Descripción" Style="{StaticResource LabelStyle}"/>
                            <TextBox Style="{StaticResource InputStyle}"
                                     Text="{Binding Descripcion, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="500"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1"
                        CornerRadius="8" Padding="20" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.03" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Plantillas de Preguntas" Style="{StaticResource LabelStyle}"
                                   Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource TipoButtonStyle}"
                                    Command="{Binding AbrirPanelMultipleCommand}" Margin="0,0,10,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE73A;"
                                               FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Multiple" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource TipoButtonStyle}"
                                    Command="{Binding AbrirPanelOrdenarCommand}" Margin="0,0,10,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE8CB;"
                                               FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Ordenar" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource TipoButtonStyle}"
                                    Command="{Binding AbrirPanelLibreCommand}" Margin="0,0,10,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE70F;"
                                               FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Libre" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource TipoButtonStyle}"
                                    Command="{Binding AbrirPanelEmparejarCommand}" Margin="0,0,10,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE71B;"
                                               FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Emparejar" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource TipoButtonStyle}"
                                    Command="{Binding AbrirPanelPausaCommand}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE769;"
                                               FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Pausa" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1"
                        CornerRadius="8" Padding="20" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.03" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Constructor de Quiz" Style="{StaticResource LabelStyle}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Preguntas añadidas al quiz"
                                   Foreground="#9CA3AF" FontSize="13" Margin="0,0,0,15"/>

                        <TextBlock Text="Aún no hay preguntas. Usa los botones de arriba para añadir."
                                   Foreground="#9CA3AF" FontSize="14" HorizontalAlignment="Center"
                                   Margin="0,20">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Preguntas.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ItemsControl ItemsSource="{Binding Preguntas}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E5E7EB" BorderThickness="1"
                                            CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" FontFamily="{StaticResource IconFont}"
                                                       Text="&#xE784;" Foreground="#9CA3AF"
                                                       VerticalAlignment="Center" Margin="0,0,12,0"/>

                                            <Border Grid.Column="1" Background="#FFF8E1" CornerRadius="4"
                                                    Padding="8,4" VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Text="{Binding Type}" Foreground="#FF9800"
                                                           FontSize="11" FontWeight="SemiBold"/>
                                            </Border>

                                            <TextBlock Grid.Column="2" Text="{Binding Content}"
                                                       VerticalAlignment="Center" FontSize="14"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Grid.Column="3" Orientation="Horizontal">
                                                <Button Width="32" Height="32" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                        Command="{Binding DataContext.SubirPreguntaCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock FontFamily="{StaticResource IconFont}"
                                                               Text="&#xE70E;" Foreground="#6B7280" FontSize="14"/>
                                                </Button>
                                                <Button Width="32" Height="32" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                        Command="{Binding DataContext.BajarPreguntaCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock FontFamily="{StaticResource IconFont}"
                                                               Text="&#xE70D;" Foreground="#6B7280" FontSize="14"/>
                                                </Button>
                                                <Button Width="32" Height="32" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                        Command="{Binding DataContext.EditarPreguntaCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock FontFamily="{StaticResource IconFont}"
                                                               Text="&#xE70F;" Foreground="#FF9800" FontSize="14"/>
                                                </Button>
                                                <Button Width="32" Height="32" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                        Command="{Binding DataContext.EliminarPreguntaCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock FontFamily="{StaticResource IconFont}"
                                                               Text="&#xE74D;" Foreground="#EF4444" FontSize="14"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Visibility="{Binding PanelMultipleVisible, Converter={StaticResource BoolToVis}}"
                        Background="White" BorderBrush="#FF9800" BorderThickness="2"
                        CornerRadius="8" Padding="30" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Nueva Pregunta — Opción Múltiple"
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,20"/>
                        <TextBlock Text="Enunciado de la pregunta *" Style="{StaticResource LabelStyle}"/>
                        <TextBox Style="{StaticResource InputStyle}" Margin="0,0,0,20"
                                 Text="{Binding TextoPregunta, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Opciones (marca el radio de la correcta)" Style="{StaticResource LabelStyle}"/>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <RadioButton Grid.Row="0" Grid.Column="0" GroupName="Correcta"
                                         VerticalAlignment="Center" Margin="0,0,10,0" IsChecked="{Binding CorrectaA}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource InputStyle}"
                                     Text="{Binding OpcionA, UpdateSourceTrigger=PropertyChanged}"/>
                            <RadioButton Grid.Row="0" Grid.Column="3" GroupName="Correcta"
                                         VerticalAlignment="Center" Margin="0,0,10,0" IsChecked="{Binding CorrectaB}"/>
                            <TextBox Grid.Row="0" Grid.Column="4" Style="{StaticResource InputStyle}"
                                     Text="{Binding OpcionB, UpdateSourceTrigger=PropertyChanged}"/>
                            <RadioButton Grid.Row="2" Grid.Column="0" GroupName="Correcta"
                                         VerticalAlignment="Center" Margin="0,0,10,0" IsChecked="{Binding CorrectaC}"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource InputStyle}"
                                     Text="{Binding OpcionC, UpdateSourceTrigger=PropertyChanged}"/>
                            <RadioButton Grid.Row="2" Grid.Column="3" GroupName="Correcta"
                                         VerticalAlignment="Center" Margin="0,0,10,0" IsChecked="{Binding CorrectaD}"/>
                            <TextBox Grid.Row="2" Grid.Column="4" Style="{StaticResource InputStyle}"
                                     Text="{Binding OpcionD, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource GrayButtonStyle}" Width="120" Margin="0,0,10,0"
                                    Command="{Binding CerrarPanelCommand}">Cancelar</Button>
                            <Button Style="{StaticResource OrangeButtonStyle}" Width="160"
                                    Command="{Binding AnadirPreguntaCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE710;"
                                               Margin="0,0,8,0" VerticalAlignment="Center" Cursor=""/>
                                    <TextBlock VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Añadir Pregunta"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EstaEditando}" Value="True">
                                                        <Setter Property="Text" Value="Guardar Cambios"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Visibility="{Binding PanelLibreVisible, Converter={StaticResource BoolToVis}}"
                        Background="White" BorderBrush="#FF9800" BorderThickness="2"
                        CornerRadius="8" Padding="30" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Nueva Pregunta — Respuesta Libre"
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,20"/>
                        <TextBlock Text="Enunciado de la pregunta *" Style="{StaticResource LabelStyle}"/>
                        <TextBox Style="{StaticResource InputStyle}" Margin="0,0,0,10"
                                 Text="{Binding TextoPregunta, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Los participantes responderán de forma abierta, sin opciones predefinidas."
                                   Foreground="#9CA3AF" FontSize="13" Margin="0,0,0,20"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource GrayButtonStyle}" Width="120" Margin="0,0,10,0"
                                    Command="{Binding CerrarPanelCommand}">Cancelar</Button>
                            <Button Style="{StaticResource OrangeButtonStyle}" Width="160"
                                    Command="{Binding AnadirPreguntaCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE710;"
                                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Añadir Pregunta"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EstaEditando}" Value="True">
                                                        <Setter Property="Text" Value="Guardar Cambios"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Visibility="{Binding PanelOrdenarVisible, Converter={StaticResource BoolToVis}}"
                        Background="White" BorderBrush="#FF9800" BorderThickness="2"
                        CornerRadius="8" Padding="30" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Nueva Pregunta — Ordenar"
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,20"/>
                        <TextBlock Text="Enunciado de la pregunta *" Style="{StaticResource LabelStyle}"/>
                        <TextBox Style="{StaticResource InputStyle}" Margin="0,0,0,20"
                                 Text="{Binding TextoPregunta, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Elementos a ordenar (mínimo 2) *" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Añádelos en el orden correcto." Foreground="#9CA3AF" FontSize="13" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource InputStyle}"
                                     Text="{Binding NuevoElementoOrdenar, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Style="{StaticResource OrangeButtonStyle}" Padding="15,10"
                                    Command="{Binding AnadirElementoOrdenarCommand}">
                                <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE710;" FontSize="16"/>
                            </Button>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding ElementosOrdenar}" Margin="0,0,0,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6"
                                            Padding="12,8" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" FontFamily="{StaticResource IconFont}"
                                                       Text="&#xE784;" Foreground="#9CA3AF" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding}" VerticalAlignment="Center" FontSize="14"/>
                                            <Button Grid.Column="2" Width="28" Height="28" Background="Transparent"
                                                    BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding DataContext.SubirElementoOrdenarCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock FontFamily="{StaticResource IconFont}"
                                                           Text="&#xE70E;" Foreground="#6B7280" FontSize="13"/>
                                            </Button>
                                            <Button Grid.Column="3" Width="28" Height="28" Background="Transparent"
                                                    BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding DataContext.BajarElementoOrdenarCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock FontFamily="{StaticResource IconFont}"
                                                           Text="&#xE70D;" Foreground="#6B7280" FontSize="13"/>
                                            </Button>
                                            <Button Grid.Column="4" Width="28" Height="28" Background="Transparent"
                                                    BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding DataContext.EliminarElementoOrdenarCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock FontFamily="{StaticResource IconFont}"
                                                           Text="&#xE74D;" Foreground="#EF4444" FontSize="13"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource GrayButtonStyle}" Width="120" Margin="0,0,10,0"
                                    Command="{Binding CerrarPanelCommand}">Cancelar</Button>
                            <Button Style="{StaticResource OrangeButtonStyle}" Width="160"
                                    Command="{Binding AnadirPreguntaCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE710;"
                                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Añadir Pregunta"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EstaEditando}" Value="True">
                                                        <Setter Property="Text" Value="Guardar Cambios"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Visibility="{Binding PanelEmparejarVisible, Converter={StaticResource BoolToVis}}"
                        Background="White" BorderBrush="#FF9800" BorderThickness="2"
                        CornerRadius="8" Padding="30" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Nueva Pregunta — Emparejar"
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,20"/>
                        <TextBlock Text="Enunciado de la pregunta *" Style="{StaticResource LabelStyle}"/>
                        <TextBox Style="{StaticResource InputStyle}" Margin="0,0,0,20"
                                 Text="{Binding TextoPregunta, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Pares (mínimo 2) *" Style="{StaticResource LabelStyle}"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource InputStyle}"
                                     Text="{Binding NuevoTermino, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Resources>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource InputStyle}">
                                        <Setter Property="Tag" Value="Término"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                            <TextBox Grid.Column="2" Style="{StaticResource InputStyle}"
                                     Text="{Binding NuevaDefinicion, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="4" Style="{StaticResource OrangeButtonStyle}" Padding="15,10"
                                    Command="{Binding AnadirParCommand}">
                                <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE710;" FontSize="16"/>
                            </Button>
                        </Grid>
                        <Grid Margin="0,0,45,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Término" Foreground="#9CA3AF" FontSize="12"/>
                            <TextBlock Grid.Column="2" Text="Definición" Foreground="#9CA3AF" FontSize="12"/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding ParesEmparejar}" Margin="0,0,0,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6"
                                            Padding="12,8" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Termino}"
                                                       VerticalAlignment="Center" FontSize="14"/>
                                            <TextBlock Grid.Column="1" Text="→" Foreground="#9CA3AF"
                                                       VerticalAlignment="Center" Margin="15,0" FontSize="16"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Definicion}"
                                                       VerticalAlignment="Center" FontSize="14"/>
                                            <Button Grid.Column="3" Width="28" Height="28" Background="Transparent"
                                                    BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding DataContext.EliminarParCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock FontFamily="{StaticResource IconFont}"
                                                           Text="&#xE74D;" Foreground="#EF4444" FontSize="13"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource GrayButtonStyle}" Width="120" Margin="0,0,10,0"
                                    Command="{Binding CerrarPanelCommand}">Cancelar</Button>
                            <Button Style="{StaticResource OrangeButtonStyle}" Width="160"
                                    Command="{Binding AnadirPreguntaCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE710;"
                                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Añadir Pregunta"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EstaEditando}" Value="True">
                                                        <Setter Property="Text" Value="Guardar Cambios"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Visibility="{Binding PanelPausaVisible, Converter={StaticResource BoolToVis}}"
                        Background="White" BorderBrush="#FF9800" BorderThickness="2"
                        CornerRadius="8" Padding="30" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Nueva Pausa / Slide intermedio"
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,20"/>
                        <TextBlock Text="Título (opcional)" Style="{StaticResource LabelStyle}"/>
                        <TextBox Style="{StaticResource InputStyle}" Margin="0,0,0,15"
                                 Text="{Binding TituloPausa, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Subtítulo (opcional)" Style="{StaticResource LabelStyle}"/>
                        <TextBox Style="{StaticResource InputStyle}" Margin="0,0,0,10"
                                 Text="{Binding SubtituloPausa, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Este slide se mostrará en pantalla sin esperar respuesta."
                                   Foreground="#9CA3AF" FontSize="13" Margin="0,0,0,20"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource GrayButtonStyle}" Width="120" Margin="0,0,10,0"
                                    Command="{Binding CerrarPanelCommand}">Cancelar</Button>
                            <Button Style="{StaticResource OrangeButtonStyle}" Width="160"
                                    Command="{Binding AnadirPreguntaCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE710;"
                                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Añadir Pausa"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EstaEditando}" Value="True">
                                                        <Setter Property="Text" Value="Guardar Cambios"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>